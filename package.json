{
  "name": "era-voice-assistant",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "src/main/electron.mjs",
  "description": "ERA — a polished, voice-first AI assistant experience.",
  "author": "Manoj Dahal",
  "repository": {
    "type": "git",
    "url": "https://github.com/manoj-dahal/Voice-Assistance.git"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "bin": {
    "era-ai": "./bin/era-ai.mjs"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"node --watch bin/era-ai.mjs\" \"vite\"",
    "build": "tsc -b && vite build",
    "start": "node bin/era-ai.mjs",
    "desktop:preview": "npm run build && electron .",
    "package:unpacked": "npm run build && electron-builder --dir",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "node scripts/verify.mjs",
    "structure": "node scripts/print-structure.mjs"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "iso-639-3": "^3.0.1",
    "lucide-react": "^1.25.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "typescript": "~5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.10"
  }
}
