# Optional: enables open-ended AI reasoning. Local voice commands work without it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
TAVILY_API_KEY=

# Optional but recommended. If omitted, ERA generates a local mode-0600 vault key.
ERA_VAULT_SECRET=
ERA_DATA_DIR=.era

# Notes vault used by POST /remember. Relative paths resolve from the project root.
NOTES_DIR=./resources/notes

# Production server port (defaults to 8787)
PORT=8787
